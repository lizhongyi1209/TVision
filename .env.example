# ===== 必填 =====

# 会话签名 + 令牌加密的根密钥。泄漏 = 所有租户令牌泄漏；换值 = 所有租户需重贴令牌。
# 生成：openssl rand -hex 32
APP_SECRET=

# 部署域名（Caddy 用它签 HTTPS 证书）
DOMAIN=tvision.example.com

# ===== 鉴权模式 =====
# token（默认）= 贴 o1key 令牌进门，多租户按令牌哈希隔离（线上模式）
# login = 上游账号登录（旧模式，代码保留）
AUTH_MODE=token

# ===== 对象存储（S3 兼容：R2 / OSS / MinIO）=====
# 不配则媒体落到容器内 /data/output（仅适合试运行——磁盘会涨满）
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
# 可选：bucket 的 CDN/公开访问基址；配了则媒体 302 到它而不是逐次签名
S3_PUBLIC_BASE=

# ===== 配额与限流 =====
# 每租户存储配额（字节），默认 2GB
TENANT_QUOTA_BYTES=2147483648
# 每租户同时进行中的生成任务上限
MAX_ACTIVE_JOBS=8
